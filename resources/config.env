# .env.example
#
# CauseLink RCA Engine — Environment Variable Reference
#
# Copy this file to .env and populate the values for your environment.
# NEVER commit .env to version control.
# All defaults shown here are safe for local/demo usage.
#
# ---- Neo4j Connection -------------------------------------------------------
#
# URI for the Neo4j instance containing the compliance ontology graph.
# For local development: bolt://localhost:7687
# For AuraDB: neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_URI=bolt://localhost:7687

# Neo4j authentication credentials.
# Leave NEO4J_PASSWORD empty when CAUSELINK_MOCK_MODE=true.
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ---- CauseLink Engine Settings ---------------------------------------------

# Set to true to run the engine with a mock Neo4j adapter and NullEvidenceService.
# Required for demos and CI pipelines without a live Neo4j instance.
# Default: false (production uses live Neo4j)
CAUSELINK_MOCK_MODE=true

# Log verbosity. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL
CAUSELINK_LOG_LEVEL=INFO

# Log output format.
# 'json' produces structured JSON logs suitable for log aggregation (ELK, Splunk).
# 'text' produces human-readable output for local development.
CAUSELINK_LOG_FORMAT=json

# Maximum ontology traversal depth per investigation.
# Range: 1-6. Higher values increase query cost and response time.
# Default: 3 (recommended for most compliance investigations)
CAUSELINK_MAX_HOPS=3

# Minimum composite score (E*T*D*H) required to mark a root cause CONFIRMED.
# Range: 0.0-1.0. Lower values produce more PROBABLE results.
# Default: 0.80 (bank-grade: require high-confidence before confirmation)
CAUSELINK_CONFIDENCE_THRESHOLD=0.80

# Maximum number of nodes returned per CanonGraph retrieval.
# Prevents runaway queries on densely-connected ontologies.
CAUSELINK_MAX_GRAPH_NODES=500

# When true, 'requested_by' and other PII-adjacent fields are hashed before
# being written to audit trace entries or logs.
CAUSELINK_AUDIT_REDACT_PII=true

# ---- API / Network ---------------------------------------------------------

# FastAPI server bind address.
CAUSELINK_API_HOST=0.0.0.0

# FastAPI server port.
CAUSELINK_API_PORT=8001

# Timeout in seconds for evidence connector calls (Splunk, Datadog, etc.).
CAUSELINK_REQUEST_TIMEOUT=30

# Timeout in seconds for Neo4j Cypher queries.
CAUSELINK_NEO4J_TIMEOUT=10
