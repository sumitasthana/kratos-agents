modules = ["python-3.12"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["glibcLocales", "libxcrypt", "libyaml"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Spark Fingerprint CLI"

[[workflows.workflow]]
name = "Spark Fingerprint CLI"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m src.cli --help"

[workflows.workflow.metadata]
outputType = "console"
